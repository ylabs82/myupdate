#!/bin/bash


# ─────────────────────────────────────────────────────────────────────────────
# Style & color variables
# ─────────────────────────────────────────────────────────────────────────────

normal=$(tput sgr0)
bold=$(tput bold)
dim=$(tput dim)

red=$(tput setaf 1)
green=$(tput setaf 2)
yellow=$(tput setaf 3)
blue=$(tput setaf 4)
magenta=$(tput setaf 5)
cyan=$(tput setaf 6)
white=$(tput setaf 7)

top_left="┌"
top_right="┐"
bottom_left="└"
bottom_right="┘"
vertical="│"
horizontal="─"
intersection_left="├"
intersection_right="┤"

light_top_left="╭"
light_top_right="╮"
light_bottom_left="╰"
light_bottom_right="╯"
light_vertical="│"
light_horizontal="─"

arrow_right="→"
arrow_up="↑"
arrow_down="↓"
check="✓"
cross_mark="✗"
menu_arrow="▶"

# Terminal width (capped at 80 for readability)
COLS=$(tput cols)
[[ $COLS -gt 80 ]] && COLS=80

# Pre-compute a full-width separator string (avoids rebuilding it on each call)
_SEP=""
for (( _i=0; _i < COLS - 2; _i++ )); do _SEP+="─"; done
unset _i


# ─────────────────────────────────────────────────────────────────────────────
# Get the current shell interpreter (supports bash, sh, zsh)
# ─────────────────────────────────────────────────────────────────────────────

interpreter=$(ps h -p $$ -o args='' | cut -f1 -d' ')


# ─────────────────────────────────────────────────────────────────────────────
# UI helpers
# ─────────────────────────────────────────────────────────────────────────────

print_header() {
  local title=" $1 "
  local len=${#title}
  local width=$(( COLS - 2 ))
  local padding_left=$(( (width - len) / 2 ))
  local padding_right=$((( (width - len) / 2 ) - (( (width - len) % 2 )) ))

  # If (width - len) % 2 is not zero, we need to add an extra space to the right padding
  if (( (width - len) % 2 != 0 )); then
    padding_right=$(( padding_right + 1 ))
  else
    padding_right=$(( padding_right - 1 ))
  fi

  echo
  printf "${bold}${blue}${top_left}"
  for ((i=0; i<width-1; i++)); do printf "${horizontal}"; done
  printf "${top_right}${normal}\n"

  printf "${bold}${blue}${vertical}${normal}"
  printf "%${padding_left}s${bold}${cyan}%s${normal}%${padding_right}s" "" "$title"
  printf "${bold}${blue}${vertical}${normal}\n"

  printf "${bold}${blue}${bottom_left}"
  for ((i=0; i<width-1; i++)); do printf "${horizontal}"; done
  printf "${bottom_right}${normal}\n"
  echo
}

print_banner() {
  local width=$(( COLS - 2 ))
  local title=" S Y S T E M   U P D A T E   M A N A G E R "
  local title_len=${#title}
  local padding=$(( (width - title_len) / 2 ))

  echo
  printf "${bold}${blue}${top_left}"
  for ((i=0; i<width-1; i++)); do printf "${horizontal}"; done
  printf "${top_right}${normal}\n"

  printf "${bold}${blue}${vertical}${normal}"
  printf "%${padding}s${bold}${magenta}%s${normal}" "" "$title"
  printf "%$((width - padding - title_len - 1))s${bold}${blue}${vertical}${normal}\n" ""

  printf "${bold}${blue}${bottom_left}"
  for ((i=0; i<width-1; i++)); do printf "${horizontal}"; done
  printf "${bottom_right}${normal}\n"
  echo
}

print_footer() {
  echo
  printf " ${dim}%s  %s  Updated: %s | Terminal: %s${normal}\n" \
    "$light_vertical" "$light_vertical" "$(date '+%Y-%m-%d %H:%M')" "$TERM"
  echo
}

print_section() {
  echo
  printf "   ${bold}${yellow}${arrow_right}${normal}  ${bold}${white}%s${normal}\n" "$1"
  printf " ${dim}${intersection_left}"
  for ((i=0; i<COLS-4; i++)); do printf "${horizontal}"; done
  printf "${normal}\n"
  echo
}

print_result() {
  local code=$1 label="$2"
  echo
  if [[ $code -eq 0 ]]; then
    printf " ${bold}${green}${check}${normal}  ${bold}${white}%s${normal} — ${bold}${green}done${normal}\n" "$label"
  else
    printf " ${bold}${red}${cross_mark}${normal}  ${bold}${white}%s${normal} — ${bold}${red}finished with errors (exit code: %d)${normal}\n" \
      "$label" "$code"
  fi
}

run_update() {
  local label="$1" func="$2"
  print_section "$label"
  $func
  local code=$?
  print_result $code "$label"
  tput civis
  return $code
}

print_summary() {
  local keys=("$@")
  local width=$((COLS - 3))
  local inner_width=$((COLS - 3))
  echo

  printf "${bold}${blue}${top_left}"
  for ((i=0; i<width; i++)); do printf "${horizontal}"; done
  printf "${top_right}${normal}\n"

  printf "${bold}${blue}${vertical}${normal}  ${bold}${white}Summary${normal}"
  printf "%$((COLS-12))s${bold}${blue}${vertical}${normal}\n" ""

  printf "${bold}${blue}${intersection_left}"
  for ((i=0; i<inner_width; i++)); do printf "${horizontal}"; done
  printf "${intersection_right}${normal}\n"

  for key in "${keys[@]}"; do
    if [[ ${results[$key]} -eq 0 ]]; then
      printf "${bold}${blue}${vertical}${normal}  ${bold}${green}${check}${normal}  ${bold}${white}%s${normal}" "$key"
      printf "%$((COLS-${#key}-8))s${bold}${blue}${vertical}${normal}\n" ""
    else
      printf "${bold}${blue}${vertical}${normal}  ${bold}${red}${cross_mark}${normal}  ${bold}${white}%s${normal}" "$key"
      printf "%$((COLS-${#key}-8))s${bold}${blue}${vertical}${normal}\n" ""
    fi
  done

  printf "${bold}${blue}${intersection_left}"
  for ((i=0; i<inner_width; i++)); do printf "${horizontal}"; done
  printf "${intersection_right}${normal}\n"

  printf "${bold}${blue}${vertical}$(printf '%*s' $((COLS-3)) '')${vertical}${normal}\n"

  printf "${bold}${blue}${bottom_left}"
  for ((i=0; i<inner_width; i++)); do printf "${horizontal}"; done
  printf "${bottom_right}${normal}\n"
}


# ─────────────────────────────────────────────────────────────────────────────
# Interactive menu
# ─────────────────────────────────────────────────────────────────────────────

function menu() {
  local menu_title=$1 output=$2
  shift 2

  local options=("$@") current=1 count=$#

  printf "${bold}${cyan}%s${normal}\n" "$menu_title"
  printf " ${dim}${arrow_up}${arrow_down} / jk  ·  Enter to select  ·  q to quit${normal}\n"
  echo

  local menu_box_lines=$(( count + 2 ))
  local header_lines=3

  draw_menu_box() {
    printf "${bold}${blue}${light_top_left}"
    for ((i=0; i<COLS-3; i++)); do printf "${light_horizontal}"; done
    printf "${light_top_right}${normal}\n"

    local idx=1
    for o in "${options[@]}"; do
      local prefix="    "
      local suffix=""
      if [[ $current == $idx ]]; then
        prefix=" ${menu_arrow}  "
        suffix="${normal}"
      fi
      printf "${bold}${blue}${vertical}${normal}${green}${prefix}${normal}%-*s${suffix}${bold}${blue}${vertical}${normal}\n" $((COLS-4-3)) "$o"
      idx=$(( idx + 1 ))
    done

    printf "${bold}${blue}${light_bottom_left}"
    for ((i=0; i<COLS-3; i++)); do printf "${light_horizontal}"; done
    printf "${light_bottom_right}${normal}\n"
  }

  draw_menu_box
  tput sc

  while true; do
    if [[ $interpreter == *"zsh"* ]]; then
      read -s -r -k 1 key
      if [[ $key == $'\e' ]]; then
        read -s -r -k 2 -t 0.1 key_rest
        key="${key}${key_rest}"
      fi
    elif [[ $interpreter == *"bash"* ]] || [[ $interpreter == *"sh"* ]]; then
      read -s -n 1 key
      if [[ $key == $'\e' ]]; then
        read -s -n 2 -t 0.1 key_rest
        key="${key}${key_rest}"
      fi
    else
      printf "${bold}${red} ERROR: UNSUPPORTED SHELL${normal}\n"
      tput cnorm; exit 1
    fi

    case "$key" in
      j|$'\e[B')
        current=$(( current + 1 ))
        [[ $current -gt $count ]] && current=1
        ;;
      k|$'\e[A')
        current=$(( current - 1 ))
        [[ $current -lt 1 ]] && current=$count
        ;;
      q|Q)
        current=$count
        break
        ;;
      $'\n'|'')
        break
        ;;
    esac

    tput rc
    for (( i=0; i < menu_box_lines; i++ )); do
      printf "\033[K\033[F"
    done
    draw_menu_box
    tput sc
  done

  if [[ $interpreter == *"zsh"* ]]; then
    eval $output="'${options[$current]}'"
  elif [[ $interpreter == *"bash"* ]] || [[ $interpreter == *"sh"* ]]; then
    eval $output="'${options[$current-1]}'"
  fi
}


# ─────────────────────────────────────────────────────────────────────────────
# Update functions
# ─────────────────────────────────────────────────────────────────────────────

function update_system() { sudo pacman -Syu; }
function update_yay()    { yay -Syu; }
function update_cargo()  { cargo install-update -a; }
function update_npm()    { npm update -g; }
function update_rust()   { rustup update; }


# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────

tput civis
clear

print_banner

menu_options=(
  "All Updates"
  "All but System/AUR"
  "System (pacman)"
  "AUR (yay)"
  "cargo packages"
  "npm global packages"
  "Rust toolchain"
  "Exit"
)

menu " ─ Choose an option ─ " menu_output "${menu_options[@]}"


declare -A results

case $menu_output in
  "System (pacman)")
    clear
    print_header "SYSTEM UPDATE"
    run_update "System (pacman)" update_system
    print_footer
    ;;

  "AUR (yay)")
    clear
    print_header "AUR  UPDATE"
    run_update "AUR (yay)" update_yay
    print_footer
    ;;

  "cargo packages")
    clear
    print_header "CARGO  UPDATE"
    run_update "cargo packages" update_cargo
    print_footer
    ;;

  "npm global packages")
    clear
    print_header "NPM  UPDATE"
    run_update "npm global packages" update_npm
    print_footer
    ;;

  "Rust toolchain")
    clear
    print_header "RUST UPDATE"
    run_update "Rust toolchain" update_rust
    print_footer
    ;;

  "All Updates")
    clear
    print_header "FULL  SYSTEM UPDATE"
    run_update "System (pacman)"     update_system;  results[system]=$?
    run_update "AUR (yay)"           update_yay;     results[yay]=$?
    run_update "cargo packages"      update_cargo;   results[cargo]=$?
    run_update "npm global packages" update_npm;     results[npm]=$?
    run_update "Rust toolchain"      update_rust;    results[rust]=$?
    print_summary system yay cargo npm rust
    print_footer
    ;;

  "All but System/AUR")
    clear
    print_header "CUSTOM  PACKAGES UPDATE"
    run_update "cargo packages"      update_cargo;  results[cargo]=$?
    run_update "npm global packages" update_npm;    results[npm]=$?
    run_update "Rust toolchain"      update_rust;   results[rust]=$?
    print_summary cargo npm rust
    print_footer
    ;;

  "Exit")
    clear
    printf "\n${bold}${cyan}Thanks for using MyUpdate!${normal}\n"
    printf "${dim}See you soon...${normal}\n\n"
    ;;
esac


echo
tput cnorm
